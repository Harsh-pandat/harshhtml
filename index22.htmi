<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Brookwood AI Support</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
background:#0f172a;
height:100vh;
overflow:hidden;
}

/* HEADER */

.header{
height:70px;
background:#020617;
display:flex;
align-items:center;
justify-content:space-between;
padding:0 20px;
color:white;
border-bottom:1px solid rgba(255,255,255,0.1);
}

.logo{
display:flex;
align-items:center;
gap:10px;
font-size:22px;
font-weight:700;
}

.logo-circle{
width:42px;
height:42px;
border-radius:50%;
background:#2563eb;
display:flex;
align-items:center;
justify-content:center;
font-size:20px;
}

.controls{
display:flex;
gap:10px;
}

select,
button{
padding:10px 14px;
border:none;
border-radius:10px;
background:#1e293b;
color:white;
font-weight:500;
cursor:pointer;
}

button:hover{
background:#2563eb;
}

/* MAIN */

.main{
display:flex;
height:calc(100vh - 70px);
}

/* WEBSITE */

.website{
width:70%;
background:white;
position:relative;
}

iframe{
width:100%;
height:100%;
border:none;
}

/* CHAT */

.chat{
width:30%;
background:#020617;
display:flex;
flex-direction:column;
border-left:1px solid rgba(255,255,255,0.1);
}

/* CHAT TOP */

.chat-top{
padding:20px;
display:flex;
align-items:center;
gap:15px;
background:#111827;
border-bottom:1px solid rgba(255,255,255,0.1);
}

.bot-avatar{
width:55px;
height:55px;
border-radius:50%;
background:#2563eb;
display:flex;
align-items:center;
justify-content:center;
font-size:24px;
}

.chat-top h2{
color:white;
font-size:18px;
}

.chat-top p{
color:#94a3b8;
font-size:12px;
}

/* MESSAGES */

.messages{
flex:1;
padding:20px;
overflow-y:auto;
display:flex;
flex-direction:column;
gap:15px;
}

.msg{
padding:14px 16px;
border-radius:15px;
font-size:14px;
line-height:1.6;
max-width:90%;
animation:fade 0.3s ease;
}

.bot{
background:#1e293b;
color:white;
align-self:flex-start;
}

.user{
background:#2563eb;
color:white;
align-self:flex-end;
}

@keyframes fade{
from{
opacity:0;
transform:translateY(10px);
}
to{
opacity:1;
transform:translateY(0);
}
}

/* INPUT */

.input-area{
padding:15px;
background:#111827;
display:flex;
gap:10px;
}

.input-area input{
flex:1;
padding:14px;
border:none;
border-radius:12px;
background:#1e293b;
color:white;
outline:none;
}

.send-btn{
background:#2563eb;
padding:14px 20px;
}

/* QUICK BUTTONS */

.quick{
display:flex;
flex-wrap:wrap;
gap:10px;
padding:10px 20px;
background:#0f172a;
}

.quick button{
background:#1e293b;
font-size:12px;
}

/* MOBILE */

@media(max-width:900px){

.main{
flex-direction:column;
}

.website{
width:100%;
height:45%;
}

.chat{
width:100%;
height:55%;
}

}

</style>
</head>
<body>

<!-- HEADER -->

<div class="header">

<div class="logo">
<div class="logo-circle">🦷</div>
Brookwood AI Support
</div>

<div class="controls">

<select id="language">

<option value="en">English</option>
<option value="hi">Hindi</option>
<option value="es">Spanish</option>
<option value="fr">French</option>
<option value="de">German</option>

</select>

<button onclick="openWebsite()">
Open Website
</button>

</div>

</div>

<!-- MAIN -->

<div class="main">

<!-- WEBSITE -->

<div class="website">

<iframe id="siteFrame"
src="https://www.brookwooddds.com/">
</iframe>

</div>

<!-- CHAT -->

<div class="chat">

<div class="chat-top">

<div class="bot-avatar">
🤖
</div>

<div>
<h2>AI Customer Assistant</h2>
<p>24/7 Professional Dental Support</p>
</div>

</div>

<!-- QUICK QUESTIONS -->

<div class="quick">

<button onclick="quickMessage('Book appointment')">
Appointment
</button>

<button onclick="quickMessage('Treatment prices')">
Pricing
</button>

<button onclick="quickMessage('Emergency dental help')">
Emergency
</button>

<button onclick="quickMessage('Insurance support')">
Insurance
</button>

</div>

<!-- MESSAGES -->

<div class="messages" id="messages">

<div class="msg bot">
👋 Welcome to Brookwood AI Support.<br><br>
We are here to help with appointments, treatment questions, pricing, insurance support and more.
</div>

</div>

<!-- INPUT -->

<div class="input-area">

<input
type="text"
id="userInput"
placeholder="Type your message..."
onkeypress="handleKey(event)"
>

<button class="send-btn" onclick="sendMessage()">
Send
</button>

</div>

</div>

</div>

<script>

const messages = document.getElementById("messages");

function addMessage(text,type){

const div = document.createElement("div");

div.classList.add("msg");

if(type==="bot"){
div.classList.add("bot");
}else{
div.classList.add("user");
}

div.innerHTML = text;

messages.appendChild(div);

messages.scrollTop = messages.scrollHeight;

}

function sendMessage(){

const input = document.getElementById("userInput");

const text = input.value.trim();

if(text==="") return;

addMessage(text,"user");

input.value="";

setTimeout(()=>{

botReply(text);

},800);

}

function quickMessage(text){

document.getElementById("userInput").value = text;

sendMessage();

}

function handleKey(event){

if(event.key==="Enter"){
sendMessage();
}

}

function botReply(message){

const lang = document.getElementById("language").value;

const msg = message.toLowerCase();

let reply = "";

/* ENGLISH */

if(lang==="en"){

if(msg.includes("appointment")){

reply = "📅 You can easily book an appointment directly from the Brookwood Dental website.";

}

else if(msg.includes("price")){

reply = "💰 Treatment pricing depends on the dental service. Please mention the treatment you need.";

}

else if(msg.includes("emergency")){

reply = "🚨 If this is a dental emergency, please contact the clinic immediately through the website contact section.";

}

else if(msg.includes("insurance")){

reply = "🛡️ We support multiple insurance providers. Please share your provider name.";

}

else{

reply = "🤖 Thank you for contacting Brookwood AI Support. Our assistant is reviewing your request.";

}

}

/* HINDI */

if(lang==="hi"){

reply = "🤖 नमस्ते, आपकी जानकारी प्राप्त हो गई है। हमारी AI सहायता टीम आपकी मदद कर रही है।";

}

/* SPANISH */

if(lang==="es"){

reply = "🤖 Hola, nuestro equipo de soporte está revisando su solicitud.";

}

/* FRENCH */

if(lang==="fr"){

reply = "🤖 Bonjour, notre équipe examine votre demande.";

}

/* GERMAN */

if(lang==="de"){

reply = "🤖 Hallo, unser Support-Team überprüft Ihre Anfrage.";

}

addMessage(reply,"bot");

}

/* OPEN WEBSITE */

function openWebsite(){

window.open(
"https://www.brookwooddds.com/",
"_blank"
);

}

/* WELCOME AUTO MESSAGE */

setTimeout(()=>{

addMessage(
"💬 You can ask about appointments, treatment plans, emergency care, pricing, insurance, or clinic information.",
"bot"
);

},2000);

</script>

</body>
</html>